{
  "manifest_version": 3,
  "name": "CoreTab",
  "version": "1.1.0",
  "description": "Default new tab page with tab management, GitHub trending, and history",
  "permissions": ["tabs", "activeTab", "storage", "history"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": ["<all_urls>"]
}